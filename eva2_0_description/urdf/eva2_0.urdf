<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="eva2_0">

  <!-- BASE -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="0.25" length="0.1"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
  </link>

  <!-- TORSO -->
  <link name="torso">
    <visual>
      <geometry>
        <box size="0.3 0.2 0.5"/>
      </geometry>
      <material name="white">
        <color rgba="0.9 0.9 0.9 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="base_to_torso" type="fixed">
    <parent link="base_link"/>
    <child link="torso"/>
    <origin xyz="0 0 0.3"/>
  </joint>

  <!-- ========== LEFT ARM ========== -->

  <link name="left_shoulder_pan">
    <visual>
      <geometry><sphere radius="0.04"/></geometry>
      <material name="blue"><color rgba="0.0 0.4 0.8 1.0"/></material>
    </visual>
  </link>

  <joint name="left_shoulder_pan_joint" type="revolute">
    <parent link="torso"/>
    <child link="left_shoulder_pan"/>
    <origin xyz="0.18 0 0.18"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <link name="left_shoulder_lift">
    <visual>
      <geometry><sphere radius="0.035"/></geometry>
      <material name="blue"><color rgba="0.0 0.4 0.8 1.0"/></material>
    </visual>
  </link>

  <joint name="left_shoulder_lift_joint" type="revolute">
    <parent link="left_shoulder_pan"/>
    <child link="left_shoulder_lift"/>
    <origin xyz="0.0 0 -0.06"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <link name="left_upper_arm">
    <visual>
      <geometry><cylinder radius="0.025" length="0.18"/></geometry>
      <material name="white"><color rgba="0.9 0.9 0.9 1.0"/></material>
    </visual>
  </link>

  <joint name="left_upper_arm_joint" type="fixed">
    <parent link="left_shoulder_lift"/>
    <child link="left_upper_arm"/>
    <origin xyz="0 0 -0.09"/>
  </joint>

  <link name="left_elbow">
    <visual>
      <geometry><sphere radius="0.03"/></geometry>
      <material name="blue"><color rgba="0.0 0.4 0.8 1.0"/></material>
    </visual>
  </link>

  <joint name="left_elbow_joint" type="revolute">
    <parent link="left_upper_arm"/>
    <child link="left_elbow"/>
    <origin xyz="0 0 -0.09"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="0.0" effort="10" velocity="1.0"/>
  </joint>

  <link name="left_lower_arm">
    <visual>
      <geometry><cylinder radius="0.022" length="0.16"/></geometry>
      <material name="white"><color rgba="0.9 0.9 0.9 1.0"/></material>
    </visual>
  </link>

  <joint name="left_lower_arm_joint" type="fixed">
    <parent link="left_elbow"/>
    <child link="left_lower_arm"/>
    <origin xyz="0 0 -0.08"/>
  </joint>

  <link name="left_wrist_roll">
    <visual>
      <geometry><sphere radius="0.025"/></geometry>
      <material name="blue"><color rgba="0.0 0.4 0.8 1.0"/></material>
    </visual>
  </link>

  <joint name="left_wrist_roll_joint" type="revolute">
    <parent link="left_lower_arm"/>
    <child link="left_wrist_roll"/>
    <origin xyz="0 0 -0.08"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="5" velocity="1.0"/>
  </joint>

  <link name="left_wrist_pitch">
    <visual>
      <geometry><sphere radius="0.025"/></geometry>
      <material name="blue"><color rgba="0.0 0.4 0.8 1.0"/></material>
    </visual>
  </link>

  <joint name="left_wrist_pitch_joint" type="revolute">
    <parent link="left_wrist_roll"/>
    <child link="left_wrist_pitch"/>
    <origin xyz="0 0 -0.04"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="5" velocity="1.0"/>
  </joint>

  <!-- ========== RIGHT ARM ========== -->

  <link name="right_shoulder_pan">
    <visual>
      <geometry><sphere radius="0.04"/></geometry>
      <material name="blue"><color rgba="0.0 0.4 0.8 1.0"/></material>
    </visual>
  </link>

  <joint name="right_shoulder_pan_joint" type="revolute">
    <parent link="torso"/>
    <child link="right_shoulder_pan"/>
    <origin xyz="-0.18 0 0.18"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <link name="right_shoulder_lift">
    <visual>
      <geometry><sphere radius="0.035"/></geometry>
      <material name="blue"><color rgba="0.0 0.4 0.8 1.0"/></material>
    </visual>
  </link>

  <joint name="right_shoulder_lift_joint" type="revolute">
    <parent link="right_shoulder_pan"/>
    <child link="right_shoulder_lift"/>
    <origin xyz="0.0 0 -0.06"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <link name="right_upper_arm">
    <visual>
      <geometry><cylinder radius="0.025" length="0.18"/></geometry>
      <material name="white"><color rgba="0.9 0.9 0.9 1.0"/></material>
    </visual>
  </link>

  <joint name="right_upper_arm_joint" type="fixed">
    <parent link="right_shoulder_lift"/>
    <child link="right_upper_arm"/>
    <origin xyz="0 0 -0.09"/>
  </joint>

  <link name="right_elbow">
    <visual>
      <geometry><sphere radius="0.03"/></geometry>
      <material name="blue"><color rgba="0.0 0.4 0.8 1.0"/></material>
    </visual>
  </link>

  <joint name="right_elbow_joint" type="revolute">
    <parent link="right_upper_arm"/>
    <child link="right_elbow"/>
    <origin xyz="0 0 -0.09"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="0.0" effort="10" velocity="1.0"/>
  </joint>

  <link name="right_lower_arm">
    <visual>
      <geometry><cylinder radius="0.022" length="0.16"/></geometry>
      <material name="white"><color rgba="0.9 0.9 0.9 1.0"/></material>
    </visual>
  </link>

  <joint name="right_lower_arm_joint" type="fixed">
    <parent link="right_elbow"/>
    <child link="right_lower_arm"/>
    <origin xyz="0 0 -0.08"/>
  </joint>

  <link name="right_wrist_roll">
    <visual>
      <geometry><sphere radius="0.025"/></geometry>
      <material name="blue"><color rgba="0.0 0.4 0.8 1.0"/></material>
    </visual>
  </link>

  <joint name="right_wrist_roll_joint" type="revolute">
    <parent link="right_lower_arm"/>
    <child link="right_wrist_roll"/>
    <origin xyz="0 0 -0.08"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="5" velocity="1.0"/>
  </joint>

  <link name="right_wrist_pitch">
    <visual>
      <geometry><sphere radius="0.025"/></geometry>
      <material name="blue"><color rgba="0.0 0.4 0.8 1.0"/></material>
    </visual>
  </link>

  <joint name="right_wrist_pitch_joint" type="revolute">
    <parent link="right_wrist_roll"/>
    <child link="right_wrist_pitch"/>
    <origin xyz="0 0 -0.04"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="5" velocity="1.0"/>
  </joint>

  <!-- ========== HEAD ========== -->

  <link name="neck">
    <visual>
      <geometry><cylinder radius="0.04" length="0.1"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
  </link>

  <joint name="torso_to_neck" type="fixed">
    <parent link="torso"/>
    <child link="neck"/>
    <origin xyz="0 0 0.3"/>
  </joint>

  <link name="head_pan">
    <visual>
      <geometry><sphere radius="0.06"/></geometry>
      <material name="white"><color rgba="0.9 0.9 0.9 1.0"/></material>
    </visual>
  </link>

  <joint name="head_pan_joint" type="revolute">
    <parent link="neck"/>
    <child link="head_pan"/>
    <origin xyz="0 0 0.08"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="5" velocity="1.0"/>
  </joint>

  <link name="head_tilt">
    <visual>
      <geometry><box size="0.15 0.12 0.12"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
  </link>

  <joint name="head_tilt_joint" type="revolute">
    <parent link="head_pan"/>
    <child link="head_tilt"/>
    <origin xyz="0 0 0.07"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5" upper="0.5" effort="5" velocity="1.0"/>
  </joint>

  <link name="head_roll">
    <visual>
      <geometry><box size="0.14 0.11 0.11"/></geometry>
      <material name="white"><color rgba="0.9 0.9 0.9 1.0"/></material>
    </visual>
  </link>

  <joint name="head_roll_joint" type="revolute">
    <parent link="head_tilt"/>
    <child link="head_roll"/>
    <origin xyz="0 0 0.0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.3" upper="0.3" effort="5" velocity="1.0"/>
  </joint>

  <!-- KINECT mounted on head -->
  <link name="kinect_link">
    <visual>
      <geometry><box size="0.28 0.06 0.05"/></geometry>
      <material name="black"><color rgba="0.0 0.0 0.0 1.0"/></material>
    </visual>
  </link>

  <joint name="head_to_kinect" type="fixed">
    <parent link="head_roll"/>
    <child link="kinect_link"/>
    <origin xyz="0.0 0 0.06"/>
  </joint>

</robot>
